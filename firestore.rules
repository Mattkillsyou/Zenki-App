rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Zenki Dojo — Firestore Security Rules
//
// Principle: default deny. Only signed-in users can read most data,
// and users can only write to their own documents.
// Admin-only write paths are gated by `allow write: if false` here
// and will be opened up via Cloud Functions when admin UI is wired.
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Admin check — either a custom claim (token.admin == true) or a seeded
    // doc at /admins/{uid}. The doc path is the easy bootstrap; wire custom
    // claims via a Cloud Function later. See ADMIN_SETUP.md.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Member profiles keyed by Firebase Auth uid.
    // Anyone signed in can read profiles (for community features).
    // Only the owner can create/update/delete their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(uid);
    }

    // Members collection — keyed by the app's local member id (not the
    // Firebase Auth uid). Anyone signed in can read for community / admin
    // browsing. Admins write from AdminMembersScreen (role flips, belt
    // promotions, etc.); members keep ownership of their own /users/{uid}
    // doc above for self-edits.
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Posts — any signed-in user can read.
    // The poster owns the post and can edit/delete their own; admins can
    // delete any post for moderation actions (Reports → Remove & Block).
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Direct-message threads — only participants read/write.
    match /threads/{threadId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if isSignedIn()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/threads/$(threadId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Follow edges — public-ish graph.
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn()
                            && resource.data.followerId == request.auth.uid;
    }

    // Attendance — any member can see class attendance; can only check
    // themselves in. No updates or deletes (audit trail).
    match /attendance/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if false;
    }

    // Product catalog — readable by any signed-in member; writes restricted
    // to admins so AdminProductsScreen can manage the catalog directly.
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Waivers — submit-only. No one reads from client (admin reads server-side).
    match /waivers/{waiverId} {
      allow read: if false;
      allow create: if isSignedIn()
                    && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if false;
    }

    // Support messages — write-only from client.
    match /supportMessages/{docId} {
      allow read: if false;
      allow create: if isSignedIn()
                    && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    // AI rate-limit state — Cloud Functions only (Admin SDK bypasses rules).
    match /aiRateLimits/{uid}/endpoints/{endpoint} {
      allow read, write: if false;
    }

    // Blocks — each user owns a /blocks/{uid}/blocked subcollection of
    // UIDs they've blocked. The owner reads/writes their own list, and
    // admins can write on the owner's behalf when actioning a report
    // (so a "Remove & Block" decision protects the reporter automatically).
    match /blocks/{uid}/blocked/{blockedUid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // Reports — users can file a report (write-only from client).
    // Admins can read the queue and update the status (dismiss / actioned)
    // directly from AdminReportsScreen; deletes still blocked so we keep
    // the audit trail.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.targetType in ['post', 'message', 'user', 'comment']
                    && request.resource.data.reason is string
                    && request.resource.data.targetId is string
                    && request.resource.data.targetUserId is string;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Admins collection — the /admins/{uid} doc opens up isAdmin() for that
    // user. Only other admins (or the console) can write.
    match /admins/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow write: if isAdmin();
    }

    // Default deny — anything not listed above is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
