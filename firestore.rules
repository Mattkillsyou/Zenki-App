rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Zenki Dojo — Firestore Security Rules
//
// Principle: default deny. Only signed-in users can read most data,
// and users can only write to their own documents.
// Admin-only write paths are gated by `allow write: if false` here
// and will be opened up via Cloud Functions when admin UI is wired.
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Admin check — either a custom claim (token.admin == true) or a seeded
    // doc at /admins/{uid}. The doc path is the easy bootstrap; wire custom
    // claims via a Cloud Function later. See ADMIN_SETUP.md.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Member profiles keyed by Firebase Auth uid.
    // Anyone signed in can read profiles (for community features).
    // Only the owner can create/update/delete their own profile.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(uid);
    }

    // Members collection — keyed by the app's local member id (not the
    // Firebase Auth uid). Anyone signed in can read for community / admin
    // browsing.
    //
    // Create: a signed-in user can create their OWN member doc as long as
    // the doc's firebaseUid matches their auth uid. This unblocks the
    // self-signup flow (Onboarding → createAccount) so new users actually
    // appear in the admin panel. Without it, only the seed members written
    // via admin-side backfill ever show up.
    //
    // Update / delete: admins always; otherwise the member can update their
    // own doc (firebaseUid match) for self-edits like avatar / bio.
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.firebaseUid == request.auth.uid);
      // Update has two non-admin paths:
      //   (a) NORMAL — existing doc already stamped with this user's
      //       firebaseUid, and the new doc preserves that stamp.
      //   (b) FIRST-TIME CLAIM — existing doc has no firebaseUid yet AND
      //       its email matches the auth user's verified email; the new
      //       doc must stamp the user's firebaseUid. Without this path
      //       any /members doc that landed without a firebaseUid (admin
      //       backfilled seed members, or an earlier signup that wrote
      //       /members but not the stamp) is permanently un-updatable
      //       by its rightful owner — which broke profile-photo uploads
      //       and silenced /members backfills on subsequent sign-ins.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.firebaseUid == request.auth.uid
                        && (
                          resource.data.firebaseUid == request.auth.uid
                          || (!('firebaseUid' in resource.data)
                              && resource.data.email == request.auth.token.email)
                        ));
      allow delete: if isAdmin();
    }

    // Posts — any signed-in user can read.
    // The poster owns the post and can edit/delete their own; admins can
    // delete any post for moderation actions (Reports → Remove & Block).
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      // Owner can update anything on their own post. Any signed-in user
      // can update — but ONLY the `likes` counter — so that the like /
      // unlike flow can increment/decrement the count without needing a
      // Cloud Function.
      allow update: if isSignedIn()
                    && (resource.data.userId == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());

      // Likes — each user owns one like-doc per post, keyed by their uid.
      // Anyone signed in can read (so feed renders the heart state); only
      // the owner can write theirs.
      match /likes/{likerUid} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(likerUid);
      }

      // Comments — anyone signed in reads; only the comment author writes.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn()
                              && resource.data.userId == request.auth.uid;
      }
    }

    // Direct-message threads — only participants read/write.
    match /threads/{threadId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if isSignedIn()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/threads/$(threadId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Follow edges — public-ish graph.
    // Legacy single-collection shape (kept for older clients).
    // `resource` is null on create — split create/delete so the right side
    // of the comparison is non-null in each case.
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.followerId == request.auth.uid;
    }

    // Active subcollection shape used by `firebaseFollow.ts`:
    //   /following/{followerUid}/follows/{followedUid}
    // The follower owns their own follows list. Anyone signed in can read
    // any user's follows list (used by getFeed to discover who to query and
    // by profile screens to show follow counts).
    match /following/{followerUid}/follows/{followedUid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(followerUid);
    }

    // Attendance — any member can see class attendance; can only check
    // themselves in. The doc carries `firebaseUid` (stamped at write time)
    // because the app's internal `memberId` is not the auth uid. No updates
    // or deletes (audit trail).
    match /attendance/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.firebaseUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Product catalog — readable by any signed-in member; writes restricted
    // to admins so AdminProductsScreen can manage the catalog directly.
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Waivers — submit-only. No one reads from client (admin reads server-side).
    match /waivers/{waiverId} {
      allow read: if false;
      allow create: if isSignedIn()
                    && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if false;
    }

    // Support messages — write-only from client.
    match /supportMessages/{docId} {
      allow read: if false;
      allow create: if isSignedIn()
                    && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    // AI rate-limit state — Cloud Functions only (Admin SDK bypasses rules).
    match /aiRateLimits/{uid}/endpoints/{endpoint} {
      allow read, write: if false;
    }

    // Blocks — each user owns a /blocks/{uid}/blocked subcollection of
    // UIDs they've blocked. The owner reads/writes their own list, and
    // admins can write on the owner's behalf when actioning a report
    // (so a "Remove & Block" decision protects the reporter automatically).
    match /blocks/{uid}/blocked/{blockedUid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // Reports — users can file a report (write-only from client).
    // Admins can read the queue and update the status (dismiss / actioned)
    // directly from AdminReportsScreen; deletes still blocked so we keep
    // the audit trail.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.targetType in ['post', 'message', 'user', 'comment']
                    && request.resource.data.reason is string
                    && request.resource.data.targetId is string
                    && request.resource.data.targetUserId is string;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Admins collection — the /admins/{uid} doc opens up isAdmin() for that
    // user. Only other admins (or the console) can write.
    match /admins/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow write: if isAdmin();
    }

    // Class schedule — one doc per day key (`Mon`, `Tue`, …) holding the
    // full classes array. Anyone signed in reads; only admins write.
    match /schedule/{dayKey} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Announcements — admin-only writes; all signed-in members read.
    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Appointments — admins manage everything; members can request their
    // own. The doc carries `firebaseUid` (stamped at write time from
    // `auth.currentUser.uid`) because the app's `memberId` is an internal
    // id ('1','2',…), not the Firebase Auth uid.
    match /appointments/{apptId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.firebaseUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Employee task templates — admins manage default + assigned tasks;
    // members can create/edit/delete their own personal tasks (source must
    // be 'personal' and the doc's `firebaseUid` must match their auth uid).
    match /employeeTasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isSignedIn()
            && request.resource.data.source == 'personal'
            && request.resource.data.firebaseUid == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.source == 'personal'
            && resource.data.firebaseUid == request.auth.uid
            && request.resource.data.source == 'personal'
            && request.resource.data.firebaseUid == request.auth.uid);
      allow delete: if isAdmin()
        || (isSignedIn()
            && resource.data.source == 'personal'
            && resource.data.firebaseUid == request.auth.uid);
    }

    // Per-day task completion records — each member owns their own.
    // Doc id is `${taskId}_${memberId}_${date}`; the doc carries
    // `firebaseUid` so rules can verify against the auth uid.
    // No updates (audit trail).
    match /taskCompletions/{compId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.firebaseUid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.firebaseUid == request.auth.uid;
      allow update: if false;
    }

    // Default deny — anything not listed above is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
