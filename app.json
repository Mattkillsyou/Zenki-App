{
  "expo": {
    "name": "Zenki Dojo",
    "slug": "zenki-dojo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1A1209"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Zenki Dojo uses your location to automatically log your visits when you arrive at the dojo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D4A017"
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zenkidojo.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Zenki Dojo uses your location to automatically log your visits when you arrive at the dojo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1209"
      },
      "package": "com.zenkidojo.app"
    }
  }
}
